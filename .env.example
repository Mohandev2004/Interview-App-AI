# MongoDB
MONGO_URL=mongodb://localhost:27017/interview-app

# JWT (email/password + Google OAuth sessions)
JWT_SECRET=your-jwt-secret-here

# Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client)
# Client secret usually starts with GOCSPX-
AUTH_SECRET=your-random-secret-for-oauth-state
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret-here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App URL (used for OAuth redirect URI)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Gemini AI (create key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Optional: defaults to gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Cloudinary (profile image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: set if API is hosted on a different origin
# NEXT_PUBLIC_API_URL=
